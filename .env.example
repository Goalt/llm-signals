# =============================================================================
# tg-channel-to-rss — пример конфигурации окружения.
# Скопируйте этот файл в .env и подставьте свои значения:
#   cp .env.example .env
#
# Файл .env должен быть в .gitignore — никогда не коммитьте настоящие токены.
# Переменные группируются по назначению; пустое значение = фича выключена.
# =============================================================================

# -----------------------------------------------------------------------------
# HTTP-сервер
# -----------------------------------------------------------------------------
# Адрес и порт, на которых слушает сервер (дефолт: 0.0.0.0:8000).
HOST=0.0.0.0
PORT=8000

# -----------------------------------------------------------------------------
# Telegram-нотификатор (опционально)
# Работает, только если заданы И TG_CHANNELS, И WEBHOOKS.
# -----------------------------------------------------------------------------
# Список каналов через запятую (без @ и без https://t.me/).
# Пример: durov,telegram
TG_CHANNELS=

# Частота опроса (Go duration: 30s, 5m, 1h). Дефолт: 5m.
POLL_INTERVAL=5m

# -----------------------------------------------------------------------------
# x.com нотификатор (опционально)
# Работает, только если заданы X_USERS, WEBHOOKS и X_BEARER_TOKEN.
# -----------------------------------------------------------------------------
# Список username'ов x.com через запятую (без @).
# Пример: elonmusk,vitalikbuterin
X_USERS=

# Bearer-токен x.com API v2. Получить: https://developer.x.com/
X_BEARER_TOKEN=

# Частота опроса x.com (Go duration). Дефолт: 5m.
X_POLL_INTERVAL=5m

# -----------------------------------------------------------------------------
# Вебхуки для нотификаторов
# Общий список, используется И Telegram-, И x.com-нотификатором.
# -----------------------------------------------------------------------------
# URL'ы через запятую. На каждый новый пост POST'ится JSON-пейлоад.
# Пример: https://hooks.example.com/tg,https://hooks.example.com/x
WEBHOOKS=

# -----------------------------------------------------------------------------
# Проксируемые API (опционально)
# Если переменная пустая — используется дефолтный публичный endpoint.
# *_AUTHORIZATION инжектится сервером, клиентский Authorization вырезается.
# -----------------------------------------------------------------------------
# Hyperliquid (/proxy/hyperliquid/*)
HYPERLIQUID_API_BASE_URL=https://api.hyperliquid.xyz
HYPERLIQUID_AUTHORIZATION=

# Polymarket (/proxy/polymarket/*)
POLYMARKET_API_BASE_URL=https://clob.polymarket.com
POLYMARKET_AUTHORIZATION=

# Bybit (/proxy/bybit/*)
BYBIT_API_BASE_URL=https://api.bybit.com
BYBIT_AUTHORIZATION=
